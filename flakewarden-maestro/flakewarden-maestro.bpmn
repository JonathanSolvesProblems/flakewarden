<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:uipath="http://uipath.org/schema/bpmn"
    id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn"
    exporter="UiPath (https://bpmn.uipath.com)" exporterVersion="1.0">
  <bpmn:process id="FlakeWardenTriage" name="FlakeWarden Triage" isExecutable="true">
    <bpmn:extensionElements>
      <uipath:migrationVersion version="11.5" />
      <uipath:variables version="v1">
        <uipath:inputOutput id="Var_AgentResp" name="AgentResp" type="object" />
        <uipath:inputOutput id="Var_Label" name="Label" type="string" />
      </uipath:variables>
      <uipath:bindings version="v1">
        <uipath:binding id="Bind_AgentName" resource="process" propertyAttribute="name" default="Agent" />
        <uipath:binding id="Bind_AgentFolder" resource="process" propertyAttribute="folderPath" default="solution_folder" />
      </uipath:bindings>
    </bpmn:extensionElements>
    <bpmn:startEvent id="Start_1" name="Failing test">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_Agent" name="Triage Classifier">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartAgentJob" version="v1" />
          <uipath:context>
            <uipath:input name="name" value="=bindings.Bind_AgentName" />
            <uipath:input name="folderPath" value="=bindings.Bind_AgentFolder" />
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"test_name":"Cart_UI_012","stack_trace":"Element reference went stale mid-interaction at CartWidget.update","recent_dom_diff":"","commit_message":"chore: bump lint config","runner_logs":"parallel shard; elevated runner load; no service incidents"}]]></uipath:input>
          <uipath:output name="Process response" type="Orchestrator.RunJob" var="Var_AgentResp" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:scriptTask id="Task_Extract" name="Read verdict" scriptFormat="JavaScript">
      <bpmn:extensionElements>
        <uipath:scriptVersion value="v3" />
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.ScriptTask" version="v1" />
          <uipath:input name="args"><![CDATA[{"resp":"=vars.Var_AgentResp"}]]></uipath:input>
          <uipath:output name="label" type="string" var="Var_Label" source="=result.response" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:script><![CDATA[
var r = resp || {};
var label = r.label || (r.output && r.output.label) || (r.Output && r.Output.label) || (r.outputArguments && r.outputArguments.label) || "real_defect";
return { response: String(label) };
]]></bpmn:script>
    </bpmn:scriptTask>
    <bpmn:exclusiveGateway id="Gw_1" name="Verdict?" default="Flow_Defect">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Flaky</bpmn:outgoing>
      <bpmn:outgoing>Flow_Env</bpmn:outgoing>
      <bpmn:outgoing>Flow_Defect</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_Flaky" name="Flaky: propose heal (human review)">
      <bpmn:incoming>Flow_Flaky</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Env" name="Environment: re-run on clean infra">
      <bpmn:incoming>Flow_Env</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Defect" name="Real defect: escalate">
      <bpmn:incoming>Flow_Defect</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_Agent" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Agent" targetRef="Task_Extract" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_Extract" targetRef="Gw_1" />
    <bpmn:sequenceFlow id="Flow_Flaky" sourceRef="Gw_1" targetRef="End_Flaky">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=vars.Var_Label == "flaky"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Env" sourceRef="Gw_1" targetRef="End_Env">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=vars.Var_Label == "environment"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Defect" sourceRef="Gw_1" targetRef="End_Defect" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_1">
    <bpmndi:BPMNPlane id="Plane_1" bpmnElement="FlakeWardenTriage">
      <bpmndi:BPMNShape id="S_Start_1" bpmnElement="Start_1"><dc:Bounds x="160" y="200" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Task_Agent" bpmnElement="Task_Agent"><dc:Bounds x="250" y="178" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Task_Extract" bpmnElement="Task_Extract"><dc:Bounds x="430" y="178" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Gw_1" bpmnElement="Gw_1"><dc:Bounds x="610" y="193" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_End_Flaky" bpmnElement="End_Flaky"><dc:Bounds x="740" y="80" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_End_Env" bpmnElement="End_Env"><dc:Bounds x="740" y="200" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_End_Defect" bpmnElement="End_Defect"><dc:Bounds x="740" y="320" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_Flow_1" bpmnElement="Flow_1"><di:waypoint x="196" y="218" /><di:waypoint x="250" y="218" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Flow_2" bpmnElement="Flow_2"><di:waypoint x="370" y="218" /><di:waypoint x="430" y="218" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Flow_3" bpmnElement="Flow_3"><di:waypoint x="550" y="218" /><di:waypoint x="610" y="218" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Flow_Flaky" bpmnElement="Flow_Flaky"><di:waypoint x="635" y="193" /><di:waypoint x="635" y="98" /><di:waypoint x="740" y="98" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Flow_Env" bpmnElement="Flow_Env"><di:waypoint x="660" y="218" /><di:waypoint x="740" y="218" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_Flow_Defect" bpmnElement="Flow_Defect"><di:waypoint x="635" y="243" /><di:waypoint x="635" y="338" /><di:waypoint x="740" y="338" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
